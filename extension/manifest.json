{
  "manifest_version": 3,
  "name": "Gemini Nano Chat (Unofficial)",
  "version": "1.0.0",
  "author": "@thejjw",
  "description": "Chat with Gemini Nano — a local AI running in your browser. This is an unofficial extension and is not affiliated with or endorsed by Google. No data sent to any server.",
  "permissions": [
    "storage",
    "sidePanel",
    "offscreen"
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Gemini Nano Chat (Unofficial)"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}